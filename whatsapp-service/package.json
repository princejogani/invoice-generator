{
  "name": "whatsapp-service",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "tunnel": "cloudflared tunnel --config config.yaml run whatsapp-service",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop whatsapp-service",
    "pm2:restart": "pm2 restart whatsapp-service",
    "pm2:logs": "pm2 logs whatsapp-service"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "mongoose": "^8.23.0",
    "whatsapp-web.js": "^1.34.6",
    "wwebjs-mongo": "^1.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pm2": "^5.3.0"
  }
}
